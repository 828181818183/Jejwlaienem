local AutoNgungu = false
local mainConnection

local HEIGHT_ABOVE = 5.8

Tab:AddToggle({
    Name = "Auto Ngungu",
    Default = false,
    Callback = function(Value)
        AutoNgungu = Value

        if Value then
            mainConnection = RunService.Heartbeat:Connect(function()
                if not AutoNgungu or not hrp then return end

                local bossFolder = workspace:FindFirstChild("World Mobs")
                    and workspace["World Mobs"]:FindFirstChild("Event Mobs")

                if not bossFolder then return end

                local targetBoss
                local nearest = math.huge

                -- TÃ¬m mob Event cÃ²n sá»‘ng gáº§n nháº¥t
                for _, mob in ipairs(bossFolder:GetChildren()) do
                    local hum = mob:FindFirstChild("Humanoid")
                    local root = mob:FindFirstChild("HumanoidRootPart")

                    if hum and root and hum.Health > 0 then
                        local dist = (hrp.Position - root.Position).Magnitude
                        if dist < nearest then
                            nearest = dist
                            targetBoss = mob
                        end
                    end
                end

                if not targetBoss then return end

                local bossHRP = targetBoss.HumanoidRootPart

                hrp.Velocity = Vector3.zero
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero

                TweenService:Create(
                    hrp,
                    TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                    {
                        CFrame = CFrame.new(
                            bossHRP.Position + Vector3.new(0, HEIGHT_ABOVE, 0),
                            bossHRP.Position
                        )
                    }
                ):Play()

                if nearest <= 30 then
                    pcall(function()
                        game:GetService("ReplicatedStorage")
                            .Packages._Index["sleitnick_knit@1.4.7"]
                            .knit.Services.SkillManagerV2.RE.ExecuteSkill
                            :FireServer(
                                "Weapons_20_3",
                                {
                                    TargetPos = bossHRP.Position
                                },
                                18
                            )
                    end)
                end
            end)
        else
            if mainConnection then
                mainConnection:Disconnect()
                mainConnection = nil
            end
        end
    end
})
